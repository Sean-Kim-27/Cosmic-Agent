# Cosmic Agent environment example.
# Copy this file to `.env` and fill in only the providers you plan to use.
# Never commit `.env` with real secrets.

# --- LLM provider credentials -------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# --- Default chat model -------------------------------------------------------
# In Docker, OpenAI is the default because Codex OAuth is not available unless
# you explicitly mount and configure that auth boundary.
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# --- Background CGI JSON parser ----------------------------------------------
# Keep this on a fast/cheap model; it runs after the user-visible stream ends.
CGI_PARSE_PROVIDER=openai
CGI_PARSE_MODEL=gpt-4o-mini
CGI_PARSE_MAX_NODES=24
CGI_PARSE_JOB_MAX_ATTEMPTS=3
CGI_PARSE_JOB_RETRY_BASE_SECONDS=2
CGI_PARSE_JOB_RETRY_MAX_SECONDS=60
CGI_PARSE_JOB_LIMIT_PER_RUN=3
CGI_PARSE_STALE_LOCK_SECONDS=600
CGI_PARSE_RECOVERY_INTERVAL_SECONDS=300
CGI_PARSE_RECOVERY_BATCH_LIMIT=100
CGI_MEMORY_MAX_INTERACTIONS=200
CGI_MEMORY_PRUNE_MIN_WEIGHT=0.05

# --- Token usage / cost dashboard --------------------------------------------
# Streaming token counts use provider-native usage metadata when available.
# They fall back to local estimates when a provider/client does not send usage.
# Set per-million rates for your active model if you want estimated USD costs.
LLM_USAGE_INPUT_COST_PER_MILLION=0
LLM_USAGE_OUTPUT_COST_PER_MILLION=0

# --- Runtime prompts ----------------------------------------------------------
SYSTEM_PROMPT=You are Cosmic Agent. Be accurate, useful, and concise.
PERSONA=default

# --- MCP tool orchestration ---------------------------------------------------
# Turn this on only after you have a trusted MCP server configured.
MCP_ENABLED=false
MCP_TRANSPORT=stdio
# MCP_STDIO_COMMAND=npx
# MCP_STDIO_ARGS=-y @modelcontextprotocol/server-filesystem /safe/context/root
# MCP_STDIO_CWD=/absolute/project/path
# MCP_SSE_URL=http://127.0.0.1:3001/mcp
# MCP_SSE_HEADERS_JSON={"Authorization":"Bearer replace-me"}
MCP_CONTEXT_MAX_CHARS=20000
MCP_TOOL_MAX_CALLS=3

# --- API security -------------------------------------------------------------
# If set, every /api/* request must include either:
# X-Cosmic-API-Key: <secret>
# or Authorization: Bearer <secret>
FRONTEND_API_SECRET=
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=20

# --- SQLite storage -----------------------------------------------------------
# The Docker Compose file sets XDG_DATA_HOME=/data inside the container.
# For local Python runs, leave these commented to use the platform default.
# CONFIG_DB_PATH=/absolute/path/to/config.sqlite3
# CGI_MEMORY_DB_PATH=/absolute/path/to/cgi-memory.sqlite3
# USAGE_DB_PATH=/absolute/path/to/usage.sqlite3

# --- Encrypted dashboard API-key overrides -----------------------------------
# Required only if you want to store API-key overrides through the settings API.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CONFIG_ENCRYPTION_KEY=

# --- Local ports --------------------------------------------------------------
COSMIC_AGENT_PORT=8000
COSMIC_DASHBOARD_PORT=5173
