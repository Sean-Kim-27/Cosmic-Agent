# Cosmic Agent environment example.
# Copy this file to `.env` and fill in only the providers you plan to use.
# Never commit `.env` with real secrets.

# --- LLM provider credentials -------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Default chat model -------------------------------------------------------
# In Docker, OpenAI is the default because Codex OAuth is not available unless
# you explicitly mount and configure that auth boundary.
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# --- Background CGI JSON parser ----------------------------------------------
# Keep this on a fast/cheap model; it runs after the user-visible stream ends.
CGI_PARSE_PROVIDER=openai
CGI_PARSE_MODEL=gpt-4o-mini
CGI_PARSE_MAX_NODES=24

# --- Runtime prompts ----------------------------------------------------------
SYSTEM_PROMPT=You are Cosmic Agent. Be accurate, useful, and concise.
PERSONA=default

# --- SQLite storage -----------------------------------------------------------
# The Docker Compose file sets XDG_DATA_HOME=/data inside the container.
# For local Python runs, leave these commented to use the platform default.
# CONFIG_DB_PATH=/absolute/path/to/config.sqlite3
# CGI_MEMORY_DB_PATH=/absolute/path/to/cgi-memory.sqlite3

# --- Encrypted dashboard API-key overrides -----------------------------------
# Required only if you want to store API-key overrides through the settings API.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CONFIG_ENCRYPTION_KEY=
